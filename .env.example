# Gigmark Environment Variables
# Copy this to .env.local and fill in your own keys
# NEVER commit .env.local to version control

# Squad Sandbox Keys (get from https://sandbox.squadco.com/dashboard)
SQUAD_SANDBOX_KEY=your_squad_sandbox_secret_key_here
APP_URL=http://localhost:3000

# AI/Chat API Keys (optional, for AI onboarding)
# Groq (recommended for onboarding) - get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Alternative AI providers (optional)
GEMINI_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=

# Next.js Environment (development by default)
NODE_ENV=development
